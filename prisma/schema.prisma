// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
  url = env("DATABASE_URL")
}

// ตารางข่าวสาร
model News {
  id        Int      @id @default(autoincrement())
  titleTh   String
  titleEn   String
  detailTh  String   @db.Text
  detailEn  String   @db.Text
  image     String? // รูปภาพใช้ตัวเดียวกันทั้ง 2 ภาษา
  createdAt DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  titleTh   String
  titleEn   String
  contentTh String   @db.Text
  contentEn String   @db.Text
  rating    Int      @default(5)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Teacher {
  id            String   @id @default(uuid())
  fNameTh       String
  lNameTh       String
  fNameEn       String
  lNameEn       String
  nationalityTh String
  nationalityEn String
  image         String
  status        Boolean  @default(true)
  review        Review[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ApplicationForm {
  id          String   @id @default(uuid())
  title       String
  firstName   String
  lastName    String
  email       String
  phone       String
  resumeUrl   String?
  coverLetter String?
  message     String?  @db.Text
  createdAt   DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // เก็บเป็น Hash (รหัสที่ถูกเข้ารหัสแล้ว)
  name      String?  // ชื่อเรียกของ Admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}