// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  // Prisma for Linux
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ตารางข่าวสาร
model News {
  id            String   @id @default(uuid())
  slug          String   @unique
  headlineTh    String
  headlineEn    String
  bodyTh        String?  @db.Text
  bodyEn        String?  @db.Text
  featuredImage String
  galleryImages Json?
  status        String   @default("Draft") // Published หรือ Draft
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  title     String
  content   String   @db.Text
  rating    Int      @default(5)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Teacher {
  id                   String    @id @default(uuid())
  title                String? // คำนำหน้า (Mr., Ms., Mrs., ฯลฯ)
  fName                String // ชื่อ (ใน UI เป็น Full Name แต่ขอแยกเก็บ fName/lName เพื่อให้ค้นหาง่ายขึ้น)
  lName                String
  country              String? // สัญชาติ/ประเทศ (ตาม UI คือ Country)
  image                String? // รูปภาพ
  schoolProject        String? // โรงเรียน / โครงการที่สังกัด
  phone                String?
  email                String?
  passportNumber       String?
  visaExpiryDate       DateTime? // วันหมดอายุ Visa
  workPermitNumber     String?
  workPermitExpiryDate DateTime? // วันหมดอายุ Work Permit
  status               String    @default("Active") // "Active", "Processing", "Warning", "Urgent"
  docReady             Boolean   @default(false) // เตรียมเอกสาร (Ready)
  docSigned            Boolean   @default(false) // สังกัดเซ็นแล้ว (Signed)
  docSubmitted         Boolean   @default(false) // ยื่นแล้ว (Submitted)
  docCompleted         Boolean   @default(false) // รับเล่มคืน (Completed)
  docNote              String?   @db.Text // Note การดำเนินการ
  review               Review[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ApplicationForm {
  id          String   @id @default(uuid())
  title       String
  firstName   String
  lastName    String
  email       String
  phone       String
  resumeUrl   String
  coverLetter String?
  message     String?  @db.Text
  status      String   @default("New") // New, Under Review, Trainee, Teacher, Rejected
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminId   Int
  admin     Admin    @relation(fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())
}

model Admin {
  id        Int           @id @default(autoincrement())
  username  String        @unique
  password  String
  name      String?
  logs      ActivityLog[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}
